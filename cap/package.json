{
  "name": "vendor-portal-cap",
  "version": "1.0.0",
  "description": "CAP backend for BRM Vendor Portal",
  "engines": { "node": ">=18" },
  "dependencies": {
    "@sap/cds": "^7",
    "@sap/xssec": "^3",
    "@sap-cloud-sdk/http-client": "^3",
    "express": "^4",
    "hdb": "^0.19"
  },
  "devDependencies": {
    "@sap/cds-dk": "^7",
    "sqlite3": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "node_modules/.bin/cds build --production || cds build --production"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "hana-cloud",
        "[development]": {
          "kind": "sqlite",
          "credentials": { "url": ":memory:" }
        }
      }
    }
  }
}
